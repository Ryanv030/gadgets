---
import Layout from '../layouts/Layout.astro'

const gadgets = [
  {
    name: "URL Parser",
    description: "Decode, encode, and break down URLs into readable components",
    href: "/gadgets/url-parser",
    icon: "🔗",
  },
  {
    name: "JSON Unwrapper",
    description: "Recursively unwrap stringified JSON and cut through LangChain wrapper noise",
    href: "/gadgets/json-unwrapper",
    icon: "{}",
  },
]
---

<Layout title="Home">
  <h1 class="text-3xl font-bold tracking-tight mb-2">Gadgets</h1>
  <p class="text-zinc-400 mb-10">A collection of small tools I actually use.</p>

  <div class="grid gap-4">
    {gadgets.map((gadget) => (
      <a
        href={gadget.href}
        class="group flex items-start gap-4 p-5 rounded-lg border border-zinc-800 bg-zinc-900/50 hover:border-zinc-700 hover:bg-zinc-900 transition-all"
      >
        <span class="text-2xl">{gadget.icon}</span>
        <div>
          <h2 class="text-lg font-medium text-zinc-100 group-hover:text-white">
            {gadget.name}
          </h2>
          <p class="text-sm text-zinc-400">{gadget.description}</p>
        </div>
      </a>
    ))}
  </div>
</Layout>
