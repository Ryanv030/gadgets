---
import Layout from '../layouts/Layout.astro'

const gadgets = [
  {
    name: "URL Parser",
    description: "Decode, encode, and break down URLs into readable components",
    href: "/gadgets/url-parser",
    icon: "🔗",
  },
  {
    name: "JSON Unwrapper",
    description: "Recursively unwrap stringified JSON and cut through LangChain wrapper noise",
    href: "/gadgets/json-unwrapper",
    icon: "{}",
  },
  {
    name: "JWT Decoder",
    description: "Decode JWT tokens — see header, payload, and expiry status",
    href: "/gadgets/jwt-decoder",
    icon: "🔑",
  },
  {
    name: "Timestamp Converter",
    description: "Convert between Unix, Google Sheets serials, ISO 8601, and human-readable dates",
    href: "/gadgets/timestamp",
    icon: "🕐",
  },
  {
    name: "Base64",
    description: "Encode and decode base64 strings with JSON auto-detection",
    href: "/gadgets/base64",
    icon: "🔄",
  },
  {
    name: "Regex Tester",
    description: "Test patterns with live match highlighting and capture groups",
    href: "/gadgets/regex",
    icon: ".*",
  },
  {
    name: "Diff Viewer",
    description: "Compare two blocks of text with inline diff highlighting",
    href: "/gadgets/diff",
    icon: "±",
  },
  {
    name: "Cron Explainer",
    description: "Translate cron expressions into plain English with next run previews",
    href: "/gadgets/cron",
    icon: "⏱",
  },
  {
    name: "Color Converter",
    description: "Convert between hex, RGB, HSL, and OKLCH color formats",
    href: "/gadgets/color",
    icon: "🎨",
  },
]
---

<Layout title="Home">
  <h1 class="text-3xl font-bold tracking-tight mb-2">Gadgets</h1>
  <p class="text-zinc-400 mb-10">A collection of small tools I actually use.</p>

  <div class="grid gap-4">
    {gadgets.map((gadget) => (
      <a
        href={gadget.href}
        class="group flex items-start gap-4 p-5 rounded-lg border border-zinc-800 bg-zinc-900/50 hover:border-zinc-700 hover:bg-zinc-900 transition-all"
      >
        <span class="text-2xl">{gadget.icon}</span>
        <div>
          <h2 class="text-lg font-medium text-zinc-100 group-hover:text-white">
            {gadget.name}
          </h2>
          <p class="text-sm text-zinc-400">{gadget.description}</p>
        </div>
      </a>
    ))}
  </div>
</Layout>
